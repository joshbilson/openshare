{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 30,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(vitest:*)",
      "Bash(eslint:*)",
      "Bash(tsc:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Bash(rm -rf /)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "implementer|debugger",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/gate.sh"
          }
        ]
      }
    ]
  }
}
