# ---------------------------------------------------------------------------
# OpenShare environment variables.
# Copy to .env.local for local web dev. Server secrets live in Convex env
# (set with `npx convex env set NAME value`), never in the client bundle.
# ---------------------------------------------------------------------------

# Convex deployment URL (public, safe to expose). Printed by `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL="https://your-deployment.convex.cloud"

# Convex HTTP actions origin (the .site domain), used by the iOS Shortcut / PWA
# share endpoint. Same id as above with a .convex.site suffix.
NEXT_PUBLIC_CONVEX_SITE_URL="https://your-deployment.convex.site"

# Public site origin, used to build shareable links (no trailing slash).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ----- The following are SERVER-SIDE ONLY: set them in Convex env, not here ---

# Spotify app credentials (client-credentials flow; owner needs Premium).
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Apple MusicKit developer token signing (ES256). The .p8 private key contents.
APPLE_MUSIC_TEAM_ID=""
APPLE_MUSIC_KEY_ID=""
APPLE_MUSIC_PRIVATE_KEY=""

# Scraping proxy used to read Spotify public pages and give InnerTube a stable
# egress IP. Format depends on provider; a single base URL + key is assumed.
SCRAPING_PROXY_URL=""
SCRAPING_PROXY_KEY=""

# Official YouTube Data API v3 key (read-only). Used ONLY as a quota-safe
# fallback for YouTube search when the unofficial InnerTube API is blocked.
# It cannot create playlists (that needs OAuth) — the recipient's one-tap save
# still uses the no-login watch_videos trick. search.list costs 100 units of a
# 10k/day quota, so it is never the primary search.
YOUTUBE_API_KEY=""
